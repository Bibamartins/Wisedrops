# ─────────────────────────────────────────────────────────────────────
# WiseDrops · Environment variables
# Setar TODAS no Netlify Dashboard → Site settings → Environment variables.
# Variáveis marcadas com ⭐ são as MAIS NOVAS (Jun/2026) — confira se já estão lá.
# ─────────────────────────────────────────────────────────────────────

# ─── Database (Supabase pooler) ──────────────────────────────────────
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-...pooler.supabase.com:6543/postgres?pgbouncer=true&schema=public"

# ─── Auth ────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="abrir-com-openssl-rand-base64-32"
NEXTAUTH_URL="https://wisedrops-303.netlify.app"
ADMIN_PASSWORD="senha-do-admin-master"

# ─── PayPal (consultas + pedidos de produto) ⭐ ────────────────────
# Crie um app sandbox em https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID="ARkRn8..."
PAYPAL_CLIENT_SECRET="EJ8x..."
PAYPAL_ENV="sandbox"  # ou "live" quando entrar em produção

# ─── Resend (e-mails transacionais) ⭐ ─────────────────────────────
# Crie em https://resend.com → API keys. Plano free envia 100/dia.
RESEND_API_KEY="re_..."
EMAIL_FROM="WiseDrops <noreply@wisedrops.com.br>"  # opcional; default: onboarding@resend.dev

# ─── HubSpot CRM (sync de contatos + deals) ⭐ ─────────────────────
# Settings → Integrations → Private Apps → Create. Scopes necessários:
#   crm.objects.contacts.read/write
#   crm.objects.deals.read/write
#   crm.schemas.contacts.read/write
#   crm.schemas.deals.read/write
# Depois rode `npm run hubspot:setup` UMA VEZ pra criar properties + pipelines.
HUBSPOT_PRIVATE_APP_TOKEN="pat-na1-..."

# ─── Daily.co (vídeo) ────────────────────────────────────────────────
DAILY_API_KEY="dapi_..."
DAILY_API_URL="https://api.daily.co/v1"
DAILY_DOMAIN="wisedrops"  # subdomínio em wisedrops.daily.co

# ─── AWS S3 (upload de documentos) ───────────────────────────────────
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_REGION="sa-east-1"
AWS_S3_BUCKET="wisedrops-uploads"

# ─── Notifications (opcional — push/SMS via Twilio) ──────────────────
FCM_SERVER_KEY=""
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER=""

# ─── ANVISA Integration (mock por enquanto) ──────────────────────────
ANVISA_API_URL="https://servicos.anvisa.gov.br"
ANVISA_POLLING_INTERVAL_MS=1800000

# ─── Redis (worker queue, futuro) ────────────────────────────────────
REDIS_URL=""

# ─── Stripe (legado, não usado no fluxo principal) ───────────────────
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
